{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "python -u .cursor/hooks/aix_ingest.py",
        "timeout": 3
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "python -u .cursor/hooks/aix_ingest.py",
        "timeout": 5
      }
    ],
    "afterAgentResponse": [
      {
        "command": "python -u .cursor/hooks/aix_ingest.py",
        "timeout": 8
      }
    ],
    "afterAgentThought": [
      {
        "command": "python -u .cursor/hooks/aix_ingest.py",
        "timeout": 8
      }
    ],
    "stop": [
      {
        "command": "python -u .cursor/hooks/aix_ingest.py",
        "timeout": 5
      }
    ]
  }
}
